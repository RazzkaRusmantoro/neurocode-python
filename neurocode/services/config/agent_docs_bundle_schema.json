{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentDocsBundle",
  "description": "Bundle of AI-Agent .md files: one main guide + N rule/playbook .mds",
  "type": "object",
  "required": ["guide", "rules"],
  "properties": {
    "guide": {
      "$ref": "#/definitions/AgentGuide",
      "description": "Main guide .md (overview, when to use, how to use each rule)"
    },
    "rules": {
      "type": "array",
      "description": "List of rule/playbook .md files",
      "minItems": 1,
      "items": { "$ref": "#/definitions/AgentRule" }
    }
  },
  "definitions": {
    "AgentGuide": {
      "type": "object",
      "required": ["name", "description", "when_to_use", "how_to_use"],
      "properties": {
        "name": { "type": "string", "description": "Slug for filename, e.g. 'guide' (without .md)" },
        "description": { "type": "string", "description": "Short description for frontmatter" },
        "metadata": {
          "type": "object",
          "properties": { "tags": { "type": "array", "items": { "type": "string" } } }
        },
        "when_to_use": { "type": "string", "description": "Body text for 'When to use' section" },
        "topic_pointers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "body", "rule_path"],
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" },
              "rule_path": { "type": "string" }
            }
          }
        },
        "how_to_use": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "description"],
            "properties": {
              "path": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "AgentRule": {
      "type": "object",
      "required": ["name", "description", "body"],
      "properties": {
        "name": { "type": "string", "description": "Slug for filename, e.g. 'timing' (without .md)" },
        "description": { "type": "string", "description": "Short description for frontmatter" },
        "metadata": {
          "type": "object",
          "properties": { "tags": { "type": "array", "items": { "type": "string" } } }
        },
        "role": { "type": "string", "description": "Optional: role of this .md" },
        "prerequisites": { "type": "array", "items": { "type": "string" } },
        "body": { "type": "string", "description": "Main markdown content (playbook)" },
        "input": { "type": "string", "description": "Optional input section" },
        "output": { "type": "string", "description": "Optional output section" }
      }
    }
  }
}
